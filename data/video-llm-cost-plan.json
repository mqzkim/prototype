        "reason": "셀프호스팅 전환 비용 대비 API 할인이 효과적"
      },
      {
        "trigger": "월 생성 5,000회+ 또는 API 비용 > MRR 35%",
        "action": "오픈소스 모델(HunyuanVideo) 셀프호스팅 시작",
        "reason": "RunPod A100 $860/mo로 무제한 생성 가능",
        "expectedSaving": "API 비용 40-60% 절감"
      },
      {
        "trigger": "월 생성 20,000회+ 또는 MAU 10,000+",
        "action": "하이브리드 (저가=셀프호스팅, 고품질=API)",
        "reason": "Kling/Veo는 API, 기본 생성은 HunyuanVideo/Wan 셀프호스팅"
      },
      {
        "trigger": "월 생성 100,000회+ 또는 Enterprise 계약",
        "action": "전용 GPU 클러스터 + 리저브드 인스턴스",
        "reason": "온디맨드 대비 40-60% 절감. SLA 보장 가능"
      }
    ]
  },
