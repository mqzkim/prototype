  "scalingPlan": {
    "phase1_mvp": {
      "stage": "Phase 1: MVP",
      "users": "0-500",
      "mrr": "$0-5K",
      "infrastructure": {
        "proxy": "Cloudflare Workers Free → Paid ($5/mo)",
        "db": "Cloudflare D1 (SQLite, Free tier 5M rows)",
        "auth": "Clerk/Auth0 Free tier",
        "monitoring": "Cloudflare Analytics (무료)"
      },
      "totalInfraCost": "$5-20/mo",
      "strategy": "API 프록시만. Kling + Gemini로 시작. 최소 비용으로 PMF 검증",
      "keyMetric": "DAU, 생성 완료율, 재방문율"
    },
    "phase2_growth": {
      "stage": "Phase 2: Growth",
      "users": "500-5,000",
      "mrr": "$5K-50K",
      "infrastructure": {
        "proxy": "Cloudflare Workers Paid ($5/mo + $0.50/M req)",
        "db": "Planetscale 또는 Supabase ($25/mo)",
        "auth": "Clerk Pro ($25/mo)",
        "queue": "Cloudflare Queues ($0.40/M messages)",
        "monitoring": "Grafana Cloud Free + Sentry ($26/mo)"
      },
      "totalInfraCost": "$80-200/mo",
      "strategy": "전체 모델 연동. 스마트 라우팅 활성화. 비용 대시보드 제공",
      "keyMetric": "ARPU, Churn Rate, Net Revenue Retention"
    },
    "phase3_scale": {
      "stage": "Phase 3: Scale",
      "users": "5,000-50,000",
      "mrr": "$50K-500K",
      "infrastructure": {
        "proxy": "Cloudflare Workers Enterprise",
        "db": "PlanetScale Pro ($39/mo+)",
        "gpu": "RunPod Serverless (HunyuanVideo 셀프호스팅 시작)",
        "cdn": "Cloudflare R2 (생성된 비디오 캐싱, $0.015/GB/mo)",
        "queue": "Cloudflare Queues + Durable Objects"
      },
      "totalInfraCost": "$500-3K/mo + GPU 비용",
      "strategy": "오픈소스 모델 셀프호스팅으로 마진 확대. 볼륨 디스카운트 협상",
      "transitionTrigger": "API 비용이 MRR의 40% 초과 시 셀프호스팅 전환 검토",
      "gpuCostIfSelfHosted": {
        "runpod_a100_ondemand": "$1.19/hr (~$860/mo always-on)",
        "modal_a100_serverless": "$2.10/hr (사용량 비례)",
        "breakeven": "월 4,300회 이상 생성 시 셀프호스팅이 API보다 저렴"
      }
    },
    "phase4_enterprise": {
      "stage": "Phase 4: Enterprise",
      "users": "50,000+",
      "mrr": "$500K+",
      "infrastructure": {
        "proxy": "멀티 리전 Cloudflare Workers",
        "gpu": "전용 GPU 클러스터 (Lambda Labs H100 $2.69/hr)",
        "storage": "Cloudflare R2 + 멀티 리전 복제",
        "infra": "Kubernetes (GPU 오토스케일링)"
      },
      "totalInfraCost": "$10K-50K/mo",
      "strategy": "프라이빗 배포 옵션 제공. 모델 파인튜닝 서비스. GPU 리저브드 인스턴스",
      "keyMetric": "Enterprise ACV, Logo Retention"
    }
  },
  "transitionDecisionMatrix": {
    "description": "유저 수 / 생성 볼륨 기준 인프라 전환 기준",
