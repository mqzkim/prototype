      "Bash(npm install)",
      "Bash(npm run build)",
      "Bash(npm run daily)",
      "Bash(npm test)",
      "Bash(npm run lint)",
      "Bash(node *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
